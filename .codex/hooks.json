{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "date +%s >> /tmp/png-p2-sessionstart-fired.txt" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/png-probe-deny.sh\"" }
        ]
      }
    ]
  }
}
